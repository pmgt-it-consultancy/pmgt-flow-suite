{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "android": {
        "image": "latest"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging"
      },
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      }
    },
    "staging": {
      "extends": "base",
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      }
    }
  }
}

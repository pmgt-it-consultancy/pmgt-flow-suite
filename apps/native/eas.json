{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "android": {
        "image": "latest",
        "gradleCommand": ":app:assembleRelease -PreactNativeArchitectures=arm64-v8a,x86_64",
        "applicationArchivePath": "**/*.apk"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging"
      },
      "android": {
        "buildType": "apk",
        "withoutCredentials": true
      }
    },
    "staging": {
      "extends": "base",
      "credentialsSource": "local",
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "staging"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "staging"
    },
    "production": {
      "extends": "base",
      "credentialsSource": "local",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "channel": "production"
    }
  }
}

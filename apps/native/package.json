{
  "name": "pmgt-flow-native",
  "version": "3.19.0",
  "main": "index.tsx",
  "scripts": {
    "dev": "npm run android:staging",
    "android": "expo run:android",
    "android:production": "APP_VARIANT=production expo run:android",
    "android:staging": "APP_VARIANT=staging expo run:android",
    "android:clean": "cd android && ./gradlew clean && cd ..",
    "prebuild": "expo prebuild --platform android",
    "prebuild:clean": "expo prebuild --platform android --clean",
    "prebuild:staging": "APP_VARIANT=staging expo prebuild --platform android",
    "prebuild:production": "APP_VARIANT=production expo prebuild --platform android",
    "prebuild:staging:clean": "APP_VARIANT=staging expo prebuild --platform android --clean",
    "prebuild:production:clean": "APP_VARIANT=production expo prebuild --platform android --clean",
    "build:dev": "eas build --profile development --platform android --local --non-interactive",
    "build:staging": "eas build --profile staging --platform android --local --non-interactive",
    "build:production": "eas build --profile production --platform android --local --non-interactive",
    "clean": "rm -rf node_modules/.cache .expo android/app/build",
    "typecheck": "tsc --noEmit",
    "ios": "expo run:ios",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:set": "node scripts/set-version.js"
  },

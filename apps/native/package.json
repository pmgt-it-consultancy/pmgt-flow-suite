  "main": "index.tsx",
  "scripts": {
    "dev": "npm run android:staging",
    "android": "expo run:android",
    "android:release": "expo run:android --variant productionRelease",
    "android:staging": "expo run:android --variant stagingDebug",
    "android:clean": "cd android && ./gradlew clean && cd ..",
    "prebuild": "expo prebuild --platform android",
    "prebuild:clean": "expo prebuild --platform android --clean",
    "build:apk:staging": "cd android && ./gradlew assembleStagingRelease",
    "build:apk:production": "cd android && ./gradlew assembleProductionRelease",
    "build:aab:production": "cd android && ./gradlew bundleProductionRelease",
    "clean": "rm -rf node_modules/.cache .expo android/app/build",
    "typecheck": "tsc --noEmit",
    "ios": "expo run:ios",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major"
  },

    "build:apk": "cd android && ./gradlew assembleRelease",
    "build:aab": "cd android && ./gradlew bundleRelease",
    "clean": "rm -rf node_modules/.cache .expo android/app/build",
    "typecheck": "tsc --noEmit",
    "ios": "expo run:ios"
  },

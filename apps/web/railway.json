{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "cd packages/backend && npx convex deploy --cmd \"cd ../../apps/web && pnpm run build\" --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL",
    "watchPatterns": ["apps/web/**", "packages/backend/**", "packages/config/**", "packages/ui/**"]
  },
  "deploy": {
    "startCommand": "cd apps/web && pnpm run start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm run build",
    "watchPatterns": ["apps/web/**", "packages/backend/**"]
  },
  "deploy": {
    "startCommand": "pnpm run start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
